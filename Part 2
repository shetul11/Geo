import pygame
import sys

pygame.init()

# Window
WIDTH = 1000
HEIGHT = 600
FPS = 60

screen = pygame.display.set_mode((WIDTH, HEIGHT))
pygame.display.set_caption("Geometry Dash Inspired Game")
clock = pygame.time.Clock()

# Colors
SKY_BLUE = (80, 180, 255)
GROUND_COLOR = (50, 50, 50)
GREEN = (0, 255, 0)
RED = (255, 0, 0)

GROUND_Y = 500

# Player
player_size = 40
player_x = 150

# Physics
gravity = 0.8
jump_strength = -14

# Scroll speed
scroll_speed = 6


def reset_game():
    global player_y, velocity_y, on_ground, obstacles

    player_y = GROUND_Y - player_size
    velocity_y = 0
    on_ground = True

    # Level layout (x-position, width, height)
    obstacles = [
        pygame.Rect(800, GROUND_Y - 40, 40, 40),
        pygame.Rect(1000, GROUND_Y - 40, 40, 40),
        pygame.Rect(1200, GROUND_Y - 80, 40, 80),
        pygame.Rect(1450, GROUND_Y - 40, 40, 40),
        pygame.Rect(1600, GROUND_Y - 120, 40, 120),
        pygame.Rect(1900, GROUND_Y - 40, 40, 40),
    ]


reset_game()

running = True

while running:
    clock.tick(FPS)

    # Events
    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            running = False

        if event.type == pygame.KEYDOWN:
            if event.key == pygame.K_SPACE and on_ground:
                velocity_y = jump_strength
                on_ground = False

    # Gravity
    velocity_y += gravity
    player_y += velocity_y

    # Ground collision
    if player_y >= GROUND_Y - player_size:
        player_y = GROUND_Y - player_size
        velocity_y = 0
        on_ground = True

    # Player rectangle
    player_rect = pygame.Rect(
        player_x,
        int(player_y),
        player_size,
        player_size
    )

    # Move obstacles left
    for obstacle in obstacles:
        obstacle.x -= scroll_speed

    # Collision detection
    for obstacle in obstacles:
        if player_rect.colliderect(obstacle):
            reset_game()

    # Draw
    screen.fill(SKY_BLUE)

    # Ground
    pygame.draw.rect(
        screen,
        GROUND_COLOR,
        (0, GROUND_Y, WIDTH, HEIGHT - GROUND_Y)
    )

    # Player
    pygame.draw.rect(screen, GREEN, player_rect)

    # Obstacles
    for obstacle in obstacles:
        pygame.draw.rect(screen, RED, obstacle)

    pygame.display.flip()

pygame.quit()
sys.exit()
